<div class="general-style">
  <div class="container mt-4">
    <div class="row justify-content-center">
      <div class="col-lg-8 col-md-10 col-12">
        <div class="p-0 position-relative">
          <div id="chat-messages" data-chat-id="<%= @chat.id %>" style="height: calc(100vh - 250px); overflow-y: auto; scroll-behavior: smooth;">
            <%= render partial: 'messages/message', collection: @chat.messages.includes(:user), as: :message %>
          </div>

          <!-- form container fixé en bas -->
          <div class="p-3" style="position: absolute; bottom: 0; left: 0; right: 0; background-color: var(--bs-body-bg); border-top: 1px solid #dee2e6;">
            <div id="message-form">
              <%= render partial: 'messages/form', locals: { chat: @chat, message: Message.new } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
